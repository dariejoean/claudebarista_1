# Configurații necesare pentru PharmaBarista
# Copiază acest fișier ca `.env` și completează valorile

# --- OBLIGATORIU ---
# Cheia API Google Gemini (obținută din Google AI Studio)
GEMINI_API_KEY=

# Secret pentru semnarea sesiunilor HTTP (generează un string aleator lung și sigur)
SESSION_SECRET=

# --- OPȚIONAL: OAuth Google Drive Sync ---
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# URI-ul de redirect configurat în Google Cloud Console
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
