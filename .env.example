# ============================================================
# PharmaBarista AI v7.1 -- Configuratii server
# Copiaza acest fisier ca `.env` si completeaza valorile.
# NICIODATA nu adauga .env in Git! (deja ignorat in .gitignore)
# ============================================================

# --- OBLIGATORIU ---

# Cheia API Google Gemini (obtinuta din Google AI Studio: https://aistudio.google.com)
GEMINI_API_KEY=

# Secret pentru semnarea sesiunilor HTTP.
# Genereaza un string aleator sigur, ex: openssl rand -hex 32
SESSION_SECRET=

# --- OBLIGATORIU IN PRODUCTIE ---

# Originea exacta a aplicatiei tale (fara slash final)
# Exemple:
#   Local:  http://localhost:3000
#   Vercel: https://pharmabarista.vercel.app
APP_ORIGIN=http://localhost:3000

# Mediul de rulare
# NODE_ENV=production

# --- OPTIONAL: OAuth Google Drive Sync ---

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# URI-ul de redirect configurat in Google Cloud Console
# Trebuie sa corespunda EXACT cu cel din Cloud Console
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
